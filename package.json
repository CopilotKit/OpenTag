{
  "name": "opentag",
  "version": "0.1.0",
  "private": true,
  "description": "OpenTag — a minimal CopilotKit bot starter for Slack. A thread-tagging assistant: it reads a thread, proposes a label, and applies it after a human-in-the-loop confirm. The open, get-started sibling of the Kite.dev triage bot. Built on @copilotkit/bot.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "tsx watch app/index.ts",
    "start": "tsx app/index.ts",
    "runtime": "tsx runtime.ts",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@copilotkit/bot": "~0.0.3",
    "@copilotkit/bot-slack": "~0.0.3",
    "@copilotkit/bot-ui": "~0.0.3",
    "@copilotkit/runtime": "^1.61.2",
    "@tanstack/ai": "^0.37.0",
    "@tanstack/ai-openai": "^0.15.8",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "dotenv": "^16.4.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.3"
  }
}
